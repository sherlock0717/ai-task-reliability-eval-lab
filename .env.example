# Copy to `.env` in the repo root (never commit real secrets).

# false / true — when true and the three OPENAI_COMPAT_* values are set, direct adapter calls a real model.
USE_REAL_LLM=false

# OpenAI-compatible Chat Completions endpoint base URL (no trailing path segment required).
# Examples: https://api.openai.com/v1  |  https://your-host/v1
OPENAI_COMPAT_BASE_URL=

OPENAI_COMPAT_API_KEY=

# Model name accepted by your provider (e.g. gpt-4o-mini).
OPENAI_COMPAT_MODEL=
